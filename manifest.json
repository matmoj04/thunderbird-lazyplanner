{
  "manifest_version": 3,
  "name": "Planner",
  "version": "1.1",
  "permissions": ["storage", "tabs"],
  
  "action": {
    "default_title": " ",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": { "id": "planner@local-dev.com" }
  },

  "web_accessible_resources": [
    {
      "resources": ["*.ttf", "*.otf"],
      "matches": ["<all_urls>"]
    }
  ]
}
